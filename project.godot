; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

resources_spreadsheet_view/array_color_tint=100.0
resources_spreadsheet_view/color_rows=true
resources_spreadsheet_view/array_min_width=128.0
resources_spreadsheet_view/resource_preview_size=32.0
resources_spreadsheet_view/clip_headers=false
resources_spreadsheet_view/dupe_arrays=true
resources_spreadsheet_view/context_menu_on_leftclick=false
resources_spreadsheet_view/fold_docks=true
resources_spreadsheet_view/resource_cell_label_mode=1
resources_spreadsheet_view/freeze_first_column=true

[application]

config/name="HEX"
run/main_scene="res://Menus/title_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameConstants="*res://Autoloads/game_constants.gd"
FilePaths="*res://Autoloads/file_paths.gd"
ControlSettings="*res://Autoloads/control_settings.gd"
GameConfig="*res://Autoloads/game_config.gd"
DifficultyService="*res://Autoloads/difficulty_service.gd"
SceneTransition="*res://Autoloads/scene_transition.gd"
InputMapper="*res://Autoloads/input_mapper.gd"
AudioBusController="*res://Autoloads/audio_bus_controller.gd"
EventBus="*res://Autoloads/event_bus.gd"
JournalManager="*res://Autoloads/journal_manager.gd"
AchievementManager="*res://Autoloads/achievement_manager.gd"
LevelManager="*res://Autoloads/level_manager.gd"
DisplaySettings="*res://Autoloads/display_settings.gd"
WeatherManager="*res://Autoloads/weather_manager.gd"
LocaleService="*res://Autoloads/locale_service.gd"
SaveManager="*res://Autoloads/save_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/size/transparent=true
window/stretch/mode="viewport"
window/stretch/aspect="expand"
window/stretch/scale=2.0

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/PaletteTools/plugin.cfg", "res://addons/ScriptEditorQoL/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/gdUnit4/plugin.cfg", "res://addons/gdscript-templates/plugin.cfg", "res://addons/resources_spreadsheet_view/plugin.cfg")

[file_customization]

folder_colors={
"res://tests/": "orange"
}

[gdunit4]

settings/common/server_connection_timeout_minutes=3
settings/test/test_discovery=true
ui/toolbar/run_overall=true

[input]

ui_accept={
"deadzone": 0.5,
"events": [{
"button_index": 1,
"device": 0,
"pressed": true,
"type": "InputEventMouseButton"
}, {
"device": 0,
"keycode": 4194309,
"pressed": true,
"type": "InputEventKey"
}, {
"device": 0,
"keycode": 32,
"pressed": true,
"type": "InputEventKey"
}]
}

[internationalization]

locale/translations=PackedStringArray("res://Resources/Localization/translations.en.translation", "res://Resources/Localization/translations.es.translation", "res://Resources/Localization/translations.ja.translation")
locale/translations_pot_files=PackedStringArray("res://Resources/level_data/test_level/dialogues/test_level_stage_1_complete.dialogue", "res://Resources/level_data/test_level/dialogues/test_level_stage_1_enter.dialogue", "res://Resources/level_data/test_level/dialogues/test_level_task_1_start_banter.dialogue", "res://Resources/level_data/test_level/dialogues/test_level_villager_conversation.dialogue", "res://Resources/level_data/zoo_test/dialogues/zoo_test_cave_entrance_whisper.dialogue", "res://Resources/level_data/zoo_test/dialogues/zoo_test_cave_secret.dialogue", "res://Resources/level_data/zoo_test/dialogues/zoo_test_stage_one_complete.dialogue", "res://Resources/level_data/zoo_test/dialogues/zoo_test_welcome_dialogue.dialogue", "res://Resources/level_data/quest_competition/dialogues/quest_competition_competition_start.dialogue", "res://Resources/level_data/quest_competition/dialogues/quest_competition_idol_enemy_claimed.dialogue", "res://Resources/level_data/quest_competition/dialogues/quest_competition_idol_player_claimed.dialogue", "res://Resources/level_data/quest_competition/dialogues/quest_competition_mission_complete.dialogue", "res://Resources/level_data/new_level/dialogues/new_level_welcome.dialogue", "res://Resources/level_data/omega_trial/dialogues/omega_trial_omega_finale_start.dialogue", "res://Resources/level_data/omega_trial/dialogues/omega_trial_omega_lore_1.dialogue", "res://Resources/level_data/omega_trial/dialogues/omega_trial_omega_victory.dialogue", "res://Resources/level_data/omega_trial/dialogues/omega_trial_omega_welcome.dialogue")
locale/translation_add_builtin_strings_to_pot=true
#locale/translations_pot_files=PackedStringArray("res://Resources/level_data/dialogue_rows/example_dialogue.dialogue", "res://Resources/dialogues/test_dialogue.dialogue", "res://Resources/level_data/dialogues/test_level_villager_conversation.dialogue")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[steam]

initialization/app_id=0
initialization/initialize_on_startup=false
initialization/embed_callbacks=false
multiplayer_peer/max_channels=4
