  "dynamic_paths": {
    "_warning": "These paths are constructed dynamically and CANNOT be fully centralized. If refactoring related directories, search-and-replace in the source files listed below.",
    "dialogue_paths": {
      "pattern": "res://Resources/level_data/{level_id}/dialogues/{level_id}_{dialogue_id}.dialogue",
      "used_in": [
        "Gameplay/narrative/task/task_controller.gd",
        "Gameplay/dialogue_action_service.gd",
        "json_to_tres.py (dialogue file generation)",
        "level/level_dialogue_entry.gd (dialogue_resource_path)"
      ],
      "refactoring_impact": "HIGH",
      "notes": "Dialogues are created dynamically during level generation. Pattern is nested under level folder."
    },
    "level_catalog_entries": {
      "pattern": "res://Resources/level_data/{level_id}/levels/{level_id}.tres",
      "source": "res://level/level_catalog.gd",
      "used_in": [
        "Autoloads/level_manager.gd",
        "level/level_flow_controller.gd",
        "Tests referring to level paths"
      ],
      "refactoring_impact": "HIGH",
      "notes": "Each level entry in LevelCatalog has its own path. Master list is in level_catalog.gd LEVELS array."
    }
  }
