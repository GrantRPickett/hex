  "_meta": {
    "description": "Centralized file paths registry readable by both Godot and Python",
    "format_version": "1.0",
    "last_updated": "2026-02-20",
    "usage_godot": "var paths_dict = JSON.parse_string(ResourceLoader.open_file(\"res://Resources/file_paths.json\").get_as_text())",
    "usage_python": "import json; with open('Resources/file_paths.json') as f: paths = json.load(f)",
    "warnings": [
      "Dialogue paths with dynamic level prefixes cannot be fully centralized - see dynamic_paths section",
      "LevelCatalog entries are master list - if moving res://level/ also update level_catalog.gd",
      "json_to_tres.py hardcodes several directory paths - update if refactoring",
      "Directories using recursive scans should be updated in their source files"
    ]
  },

